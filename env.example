# ─────────────────────────────────────────────────────────────
#  TEXOFILO — Cloudflare Worker — Environment Variables
#
#  Do NOT commit real values. This file is just a reference.
#
#  How to set these:
#    Cloudflare Dashboard → Workers & Pages → your worker
#    → Settings → Variables and Secrets → Add variable
#
#  Mark sensitive values (API secrets, passwords) as "Secret"
#  so they are encrypted and never shown in the dashboard again.
# ─────────────────────────────────────────────────────────────

# ── Cloudinary (public uploads) ──────────────────────────────
# Create a free account at https://cloudinary.com
# Find these in: Cloudinary Dashboard → Settings → API Keys

CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret          # ← mark as Secret

# ── Cloudinary (admin uploads — optional) ────────────────────
# You can use the same account as above, or a separate one
# with different upload presets / quotas for admin use.

ADMIN_CLOUD_NAME=your_admin_cloudinary_cloud_name
ADMIN_API_KEY=your_admin_cloudinary_api_key
ADMIN_API_SECRET=your_admin_cloudinary_api_secret  # ← mark as Secret

# ── Admin Panel ───────────────────────────────────────────────
# Password to access the /admin panel. Choose something strong.

ADMIN_PASSWORD=choose_a_strong_password_here       # ← mark as Secret

# ── Firebase Realtime Database ────────────────────────────────
# Find DB URL in: Firebase Console → Realtime Database → Data tab
# Find DB secret in: Project Settings → Service Accounts
#   → Database Secrets (legacy) → Show secret

FIREBASE_DB_URL=https://your-project-default-rtdb.region.firebasedatabase.app
FIREBASE_DB_SECRET=your_firebase_database_secret  # ← mark as Secret
